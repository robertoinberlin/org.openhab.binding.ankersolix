### Get Scene Info
### Returns site scene/layout information.
POST {{base_url}}/power_service/v1/site/get_scen_info
Content-Type: application/json
Model-Type: DESKTOP
App-Name: anker_power
Os-Type: android
Country: {{country}}
Timezone: {{timezone}}
x-auth-token: {{auth_token}}
gtoken: {{gtoken}}

{
  "site_id": "{{site_id}}"
}

> {%
    client.test("Get scene info successful", function () {
        client.assert(response.status === 200, "Expected 200 OK");
    });
%}

