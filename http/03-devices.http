### ============================================================
### Anker Solix API - Device Parameters & Attributes
### ============================================================

### Get Related and Bound Devices
### Returns all devices bound to the account.
POST {{base_url}}/power_service/v1/app/get_relate_and_bind_devices
Content-Type: application/json
Model-Type: DESKTOP
App-Name: anker_power
Os-Type: android
Country: {{country}}
Timezone: {{timezone}}
x-auth-token: {{auth_token}}
gtoken: {{gtoken}}

{}

> {%
    client.test("Get bound devices successful", function () {
        client.assert(response.status === 200, "Expected 200 OK");
    });
%}

###

### Get Device Param - Schedule (param_type=6)
### Returns SB2/SB3 schedule configuration (home load presets).
POST {{base_url}}/power_service/v1/site/get_site_device_param
Content-Type: application/json
Model-Type: DESKTOP
App-Name: anker_power
Os-Type: android
Country: {{country}}
Timezone: {{timezone}}
x-auth-token: {{auth_token}}
gtoken: {{gtoken}}

{
  "site_id": "{{site_id}}",
  "param_type": 6
}

> {%
    client.test("Get device param (schedule) successful", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        var body = response.body;
        client.assert(body.code === 0, "Expected code 0, got: " + body.code + " - " + body.msg);
    });
%}

###

