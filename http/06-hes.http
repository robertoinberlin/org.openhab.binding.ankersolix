### ============================================================
### Anker Solix API - HES Service (Solarbank 3 Pro)
### ============================================================

### Get System Running Info
### Returns real-time system running information for a HES site.
POST {{base_url}}/charging_hes_svc/get_system_running_info
Content-Type: application/json
Model-Type: DESKTOP
App-Name: anker_power
Os-Type: android
Country: {{country}}
Timezone: {{timezone}}
x-auth-token: {{auth_token}}
gtoken: {{gtoken}}

{
  "siteId": "{{site_id}}"
}

> {%
    client.test("Get system running info successful", function () {
        client.assert(response.status === 200, "Expected 200 OK");
    });
%}

###

### Get HES Device Info
### Returns detailed device information for HES devices.
POST {{base_url}}/charging_hes_svc/get_hes_dev_info
Content-Type: application/json
Model-Type: DESKTOP
App-Name: anker_power
Os-Type: android
Country: {{country}}
Timezone: {{timezone}}
x-auth-token: {{auth_token}}
gtoken: {{gtoken}}

{
  "site_id": "{{site_id}}",
  "device_sn": "{{device_sn}}"
}

> {%
    client.test("Get HES device info successful", function () {
        client.assert(response.status === 200, "Expected 200 OK");
    });
%}

###

### Get Energy Statistics
### Returns energy statistics from the HES service.
POST {{base_url}}/charging_hes_svc/get_energy_statistics
Content-Type: application/json
Model-Type: DESKTOP
App-Name: anker_power
Os-Type: android
Country: {{country}}
Timezone: {{timezone}}
x-auth-token: {{auth_token}}
gtoken: {{gtoken}}

{
  "site_id": "{{site_id}}",
  "device_sn": "{{device_sn}}",
  "type": "day",
  "start_time": "2025-01-01",
  "end_time": "2025-01-31"
}

> {%
    client.test("Get energy statistics successful", function () {
        client.assert(response.status === 200, "Expected 200 OK");
    });
%}

###
