### ============================================================
### Anker Solix API - Device Controls (Write Operations)
### ============================================================
### WARNING: These requests modify device settings.
### Use with caution!
### ============================================================

### Set Output Power Limit
### Sets the AC output power limit (power_limit) in watts.
POST {{base_url}}/power_service/v1/app/device/set_device_attrs
Content-Type: application/json
Model-Type: DESKTOP
App-Name: anker_power
Os-Type: android
Country: {{country}}
Timezone: {{timezone}}
x-auth-token: {{auth_token}}
gtoken: {{gtoken}}

{
  "device_sn": "{{device_sn}}",
  "attributes": {
    "power_limit": 800
  }
}

> {%
    client.test("Set output power limit successful", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        var body = response.body;
        client.assert(body.code === 0, "Expected code 0, got: " + body.code + " - " + body.msg);
    });
    client.log("Output power limit set to 800 W");
%}

