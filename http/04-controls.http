### Enable Grid Export
### Sets switch_0w: 0 = enable export.
POST {{base_url}}/power_service/v1/app/device/set_device_attrs
Content-Type: application/json
Model-Type: DESKTOP
App-Name: anker_power
Os-Type: android
Country: {{country}}
Timezone: {{timezone}}
x-auth-token: {{auth_token}}
gtoken: {{gtoken}}

{
  "device_sn": "{{device_sn}}",
  "attributes": {
    "switch_0w": 0
  }
}

> {%
    client.test("Enable grid export successful", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        var body = response.body;
        client.assert(body.code === 0, "Expected code 0, got: " + body.code + " - " + body.msg);
    });
    client.log("Grid export ENABLED");
%}

###

### Set Multiple Attributes at Once
### Example: set output limit + PV limit + enable grid export.
POST {{base_url}}/power_service/v1/app/device/set_device_attrs
Content-Type: application/json
Model-Type: DESKTOP
App-Name: anker_power
Os-Type: android
Country: {{country}}
Timezone: {{timezone}}
x-auth-token: {{auth_token}}
gtoken: {{gtoken}}

{
  "device_sn": "{{device_sn}}",
  "attributes": {
    "power_limit": 600,
    "pv_power_limit": 1000,
    "switch_0w": 0
  }
}

> {%
    client.test("Set multiple attributes successful", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        var body = response.body;
        client.assert(body.code === 0, "Expected code 0, got: " + body.code + " - " + body.msg);
    });
    client.log("Multiple device attributes set");
%}

###

### Set Home Load (via schedule)
### Sets a simple all-day home load preset in watts.
### Uses param_type=6 (SB2/SB3 schedule), cmd=17.
POST {{base_url}}/power_service/v1/site/set_site_device_param
Content-Type: application/json
Model-Type: DESKTOP
App-Name: anker_power
Os-Type: android
Country: {{country}}
Timezone: {{timezone}}
x-auth-token: {{auth_token}}
gtoken: {{gtoken}}

{
  "site_id": "{{site_id}}",
  "param_type": "6",
  "cmd": 17,
  "param_data": "{\"mode_type\":3,\"custom_rate_plan\":[{\"index\":0,\"week\":[0,1,2,3,4,5,6],\"ranges\":[{\"start_time\":\"00:00\",\"end_time\":\"24:00\",\"power\":200}]}],\"default_home_load\":200,\"max_load\":800,\"min_load\":0,\"step\":10}"
}

> {%
    client.test("Set home load successful", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        var body = response.body;
        client.assert(body.code === 0, "Expected code 0, got: " + body.code + " - " + body.msg);
    });
    client.log("Home load set to 200 W (all-day schedule)");
%}

