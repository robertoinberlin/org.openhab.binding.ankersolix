###

### Disable Grid Export
### Sets switch_0w: 1 = disable export (0 W), 0 = enable export.
### Note: the value is INVERTED — 1 means OFF, 0 means ON.
POST {{base_url}}/power_service/v1/app/device/set_device_attrs
Content-Type: application/json
Model-Type: DESKTOP
App-Name: anker_power
Os-Type: android
Country: {{country}}
Timezone: {{timezone}}
x-auth-token: {{auth_token}}
gtoken: {{gtoken}}

{
  "device_sn": "{{device_sn}}",
  "attributes": {
    "switch_0w": 1
  }
}

> {%
    client.test("Disable grid export successful", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        var body = response.body;
        client.assert(body.code === 0, "Expected code 0, got: " + body.code + " - " + body.msg);
    });
    client.log("Grid export DISABLED (0 W export)");
%}

