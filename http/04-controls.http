### Set Power Cutoff (Minimum SOC)
### Sets the minimum battery SOC via power cutoff.
POST {{base_url}}/power_service/v1/app/compatible/set_power_cutoff
Content-Type: application/json
Model-Type: DESKTOP
App-Name: anker_power
Os-Type: android
Country: {{country}}
Timezone: {{timezone}}
x-auth-token: {{auth_token}}
gtoken: {{gtoken}}

{
  "site_id": "{{site_id}}",
  "device_sn": "{{device_sn}}",
  "cutoff_data_id": 20
}

> {%
    client.test("Set power cutoff successful", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        var body = response.body;
        client.assert(body.code === 0, "Expected code 0, got: " + body.code + " - " + body.msg);
    });
    client.log("Power cutoff (min SOC) set to id: 20");
%}

